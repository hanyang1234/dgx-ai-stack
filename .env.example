# =============================================================================
# AI Stack – Environment Variables
# Copy this file to .env and fill in all values before running docker compose up
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic (primary/fallback LLM provider for OpenClaw)
# Get your key at: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# -----------------------------------------------------------------------------
# OpenClaw Gateway Token
# Authenticates requests to the OpenClaw gateway HTTP API.
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN=REPLACE_WITH_RANDOM_HEX_64_CHARS

# -----------------------------------------------------------------------------
# Telegram integration (optional – leave blank to disable)
# Create a bot via @BotFather on Telegram
# -----------------------------------------------------------------------------
TELEGRAM_TOKEN=

# -----------------------------------------------------------------------------
# Open WebUI (optional overrides – the image has sane defaults)
# Leave WEBUI_SECRET_KEY blank to let Open WebUI auto-generate one.
# If you set it explicitly it must stay consistent across restarts.
# -----------------------------------------------------------------------------
WEBUI_SECRET_KEY=

# -----------------------------------------------------------------------------
# Additional OpenAI-compatible provider keys (optional)
# Uncomment and fill in if you want cloud-hosted fallback providers
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-REPLACE
# GROQ_API_KEY=gsk_REPLACE

# AgentMail – email integration skill
# Get your key at: https://console.agentmail.to
AGENTMAIL_API_KEY=
